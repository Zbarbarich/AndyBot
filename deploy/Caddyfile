# Replace yourdomain.com with your actual domain before first run.
# Caddy will obtain and renew a Let's Encrypt certificate automatically.
# IP-only (no TLS): use http://138.2.220.34 so Caddy does not redirect HTTP→HTTPS.
http://138.2.220.34 {
    encode gzip
    handle /api/* {
        reverse_proxy api-gateway:3000
    }
    handle {
        reverse_proxy frontend:80
    }
}

andy-bot.com, www.andy-bot.com {
    encode gzip
    handle /api/* {
        reverse_proxy api-gateway:3000
    }
    handle {
        reverse_proxy frontend:80
    }
}
