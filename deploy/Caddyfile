# Replace yourdomain.com with your actual domain before first run.
# Caddy will obtain and renew a Let's Encrypt certificate automatically.
# For IP-only access: http://138.2.220.34 or https://138.2.220.34 (browser will show cert warning; proceed to continue).
138.2.220.34 {
    tls internal
    encode gzip
    handle /api/* {
        reverse_proxy api-gateway:3000
    }
    handle {
        reverse_proxy frontend:80
    }
}

yourdomain.com {
    encode gzip
    handle /api/* {
        reverse_proxy api-gateway:3000
    }
    handle {
        reverse_proxy frontend:80
    }
}
