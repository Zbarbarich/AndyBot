# Copy to deploy/.env and fill in values. Do not commit .env.

# PostgreSQL (used by postgres container and all backend services)
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=the_nineteenth_chamber

# JWT (must match across api-gateway and auth-service)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=1h

# Optional: CORS for production (API gateway). Comma-separated if multiple.
# Set to your app URL so the browser allows requests (e.g. https://yourdomain.com).
CORS_ORIGIN=

# Optional: PDF service
COMPANY_NAME=
COMPANY_LOGO_URL=
